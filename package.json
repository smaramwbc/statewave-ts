{
  "name": "@statewavedev/sdk",
  "version": "0.7.1",
  "description": "Official TypeScript SDK for Statewave — the open-source memory runtime for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "keywords": [
    "statewave",
    "ai",
    "agents",
    "memory",
    "context",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-ts.git"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave-ts/issues"
  },
  "homepage": "https://statewave.ai",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^6.0",
    "vitest": "^4.1"
  }
}
